{
  "name": "arabic-english-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Arabic-first English learning PWA (Vite + React + Supabase, Capacitor-ready).",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "dist:copy": "node scripts/sync-dist.mjs",
    "assets:gen": "node scripts/gen-assets.mjs",
    "ios:add": "npm run dist:copy && cap add ios",
    "ios:copy": "npm run dist:copy && cap copy ios",
    "ios:sync": "npm run dist:copy && cap sync ios",
    "ios:assets": "capacitor-assets generate --ios",
    "ios:open": "cap open ios",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "functions:serve": "supabase functions serve",
    "seed": "node supabase/seed/load.mjs",
    "seed:validate": "node supabase/seed/validate.mjs",
    "audio:generate": "node supabase/scripts/generate-audio.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.107.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
