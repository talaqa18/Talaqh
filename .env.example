# ==============================================================================
#  Environment variables — CLIENT vs SERVER split
# ==============================================================================
#
#  ⚠️  SECURITY RULE (CLAUDE.md: "Never hardcode keys", "keep secret keys
#      server-side"):
#
#  Vite STATICALLY INLINES every `VITE_`-prefixed variable into the client
#  JavaScript bundle that ships to the browser. Anything with a `VITE_` prefix
#  is PUBLIC — readable by anyone who opens devtools or views source.
#
#  => Only put PUBLISHABLE values behind `VITE_`. Never a secret key.
#  => Secret keys (Azure Speech, LLM, TTS) are SERVER-ONLY. They are read
#     exclusively inside Supabase Edge Functions via Deno.env.get(...), set
#     with `supabase secrets set ...`, and NEVER reach the browser.
#
#  Copy this file to `.env` and fill in values locally. Never commit `.env`.
# ==============================================================================


# ------------------------------------------------------------------------------
#  CLIENT — safe to ship in the browser bundle (VITE_ prefix = PUBLIC)
# ------------------------------------------------------------------------------
# The Supabase URL and the *anon* key are designed to be public; they are
# protected by Row Level Security, not by secrecy. These are the ONLY secrets-
# adjacent values allowed to carry the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ------------------------------------------------------------------------------
#  SERVER — Supabase Edge Functions ONLY. NEVER prefix these with VITE_.
# ------------------------------------------------------------------------------
# These are read with Deno.env.get(...) inside functions under
# `supabase/functions/`. In production they are stored as Supabase secrets:
#
#     supabase secrets set SPEECH_API_KEY=xxxx SPEECH_REGION=eastus
#     supabase secrets set LLM_API_KEY=xxxx
#     supabase secrets set TTS_API_KEY=xxxx
#
# For local function dev, put them in `supabase/functions/.env` (git-ignored),
# NOT in this Vite `.env`.

# Azure AI Speech — pronunciation assessment + speech-to-text.
# The raw subscription key NEVER reaches the browser. The client calls the
# `speech-token` Edge Function, which mints a short-lived Azure auth token
# (valid ~10 min) that the browser Speech SDK uses via
# SpeechConfig.fromAuthorizationToken(token, region). See
# supabase/functions/speech-token/README.md.
SPEECH_API_KEY=
SPEECH_REGION=

# Conversation tutor LLM (server-only). The client calls an Edge Function that
# proxies to the LLM; the key is never exposed to the browser.
LLM_API_KEY=

# Text-to-speech (server-only, optional — only if not pre-generating unit audio).
# Used by an Edge Function to synthesize clips; the key is never exposed.
TTS_API_KEY=
