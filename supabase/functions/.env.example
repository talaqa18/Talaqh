# ============================================================================
# supabase/functions/.env.example — SERVER-ONLY secrets for Edge Functions
# ----------------------------------------------------------------------------
# These values are read via Deno.env.get(...) INSIDE Supabase Edge Functions and
# must NEVER reach the browser bundle. Do NOT prefix them with VITE_ — anything
# VITE_* is inlined into the public client build. The trust boundary depends on
# these staying server-side (CLAUDE.md "AI key safety", integrity rule 7).
#
# This file is a COMMITTED TEMPLATE: it lists the names with placeholder values
# only. Real values live in:
#   - local dev:  supabase/functions/.env  (gitignored) loaded by
#                 `supabase functions serve --env-file supabase/functions/.env`
#   - deployed:   `supabase secrets set KEY=value`  (stored in the project)
#
# Copy this file to supabase/functions/.env and fill in real values for local
# dev. NEVER commit the filled-in .env.
#
# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# auto-injected into deployed functions by the platform — you only need them in
# the local .env file (and in CI). They are listed here for completeness.
# ============================================================================

# --- Azure AI Speech (pronunciation assessment + speech-to-text) ------------
# The speech-token Edge Function exchanges SPEECH_API_KEY for a short-lived
# Azure authorization token so the raw key never reaches the client.
SPEECH_API_KEY=your-azure-speech-subscription-key
# Azure region for the Speech resource, e.g. eastus, westeurope.
SPEECH_REGION=eastus

# --- Conversation tutor LLM -------------------------------------------------
# API key for the LLM that powers the 3-minute conversation tutor (output
# capped at ~300 tokens/reply; required words chosen server-side).
LLM_API_KEY=your-llm-provider-api-key

# --- Speech-to-text fallback (Whisper) --------------------------------------
# Used by the stt-proxy function (swappable fallback; the PRIMARY STT path is the
# Azure token-mint used client-side). If unset, stt-proxy falls back to LLM_API_KEY.
STT_API_KEY=your-whisper-or-openai-api-key

# --- Text-to-speech fallback ------------------------------------------------
# Used only when a clip is not pre-generated in Supabase Storage (the primary
# path). Counts against the tts_fallback daily quota.
TTS_API_KEY=your-tts-provider-api-key

# --- CORS allowlist ---------------------------------------------------------
# Comma-separated deployed web origin(s) the Edge Functions accept (see
# _shared/cors.ts). localhost + capacitor origins are always allowed for dev.
#   e.g. APP_ORIGIN=https://app.yourdomain.com
APP_ORIGIN=

# --- Supabase (auto-injected when deployed; set locally / in CI) ------------
# Privileged service-role key. Bypasses RLS and can write trusted columns via
# DEFINER RPCs / direct writes — SERVER-ONLY, NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project URL and public anon key (anon is safe client-side, listed here so the
# local --env-file run has them too).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
